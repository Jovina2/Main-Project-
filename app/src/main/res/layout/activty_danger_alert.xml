<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🚨 Allergy Risk Details"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#B00020"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- Food Name -->
        <TextView
            android:id="@+id/txtFood"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Food:"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <!-- Allergens -->
        <TextView
            android:id="@+id/txtAllergens"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Detected Allergens:"
            android:textSize="16sp"
            android:layout_marginBottom="12dp"/>

        <!-- Risk Level -->
        <TextView
            android:id="@+id/txtRisk"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Risk Level:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <!-- Confidence -->
        <TextView
            android:id="@+id/txtConfidence"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Confidence:"
            android:textSize="16sp"
            android:layout_marginBottom="12dp"/>

        <!-- Detailed Message -->
        <TextView
            android:id="@+id/txtMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Detailed message here..."
            android:textSize="15sp"
            android:padding="10dp"
            android:background="#FFE0E0"
            android:layout_marginBottom="20dp"/>

        <!-- Back Button -->
        <Button
            android:id="@+id/btnClose"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="OK"
            android:backgroundTint="#B00020"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btnRecommendation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="View Recommendations"
            android:layout_marginTop="16dp"/>
    </LinearLayout>

</ScrollView>